" Compatibility
if &compatible
	set nocompatible
endif
set cpoptions+=EgnW

""
""" VIM XDG base directories
""""
source $XDG_CONFIG_HOME/vim/xdg.vim

""
"""  Options
""""
runtime! options.vim

""
"""  Keymaps
""""
runtime! keymaps.vim

""
"""  Autocmds
""""
runtime! autocmds.vim

""
"""  Colorschemes
""""
let g:polyglot_disabled = [ 'sensible', 'ftdetect' ]

packadd! onedark.vim
packadd! everforest

let g:everforest_background = 'hard'
let g:everforest_disable_italic_comment = 1
let g:everforest_sign_column_background = 'none'
let g:everforest_ui_contrast = 'high'
let g:everforest_show_eob = 0
let g:everforest_diagnostic_text_highlight = 1
let g:everforest_better_performance = 1

let g:gruvbox_italic = 0
let g:gruvbox_contrast_dark = 'hard'
let g:gruvbox_hls_cursor = 'red'
let g:gruvbox_sign_column = 'bg0'
let g:gruvbox_invert_selection = 0
let g:gruvbox_invert_indent_guides = 1
let g:gruvbox_improved_strings = 1
let g:gruvbox_improved_warnings = 1

let g:tokyonight_style = 'storm'
let g:tokyonight_enable_italic = 0
let g:tokyonight_disable_italic_comment = 1

silent! colorscheme everforest

""
""" Plugins
""""
let g:snips_author = 'Jonatha Gabriel'

let g:lexima_map_escape = 'jk'
let g:lexima_accept_pum_with_enter = 1

let NERDCommentWholeLinesInVMode = 1
let NERDRemoveExtraSpaces = 1
let NERDSpaceDelims = 1
let NERDTrimTrailingWhitespace = 1

let g:gitgutter_sign_added = '+'
let g:gitgutter_sign_modified = '~'
let g:gitgutter_sign_removed = '_'
let g:gitgutter_sign_removed_first_line = '‾'
let g:gitgutter_sign_removed_above_and_below = '_¯'
let g:gitgutter_sign_modified_removed = '~_'
let g:gitgutter_preview_win_floating = 1
let g:gitgutter_use_location_list = 1

