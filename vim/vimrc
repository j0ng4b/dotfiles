function! SyntasticCheckHook(errors) abort
	let l:max_size = g:syntastic_loc_list_height

	if !empty(a:errors)
		let g:syntastic_loc_list_height = min([len(a:errors), l:max_size])
	endif

	call lightline#update()
endfunction

