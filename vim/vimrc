function! LightlineFilename() abort
	let l:modified = &modified ? '’Ż¬ ' : ''
	let l:filename = expand('%:t') ==# '' ? '[No Name]' : expand('%:t')
	let l:readonly = &readonly ? ' Ņéó' : ''

	return l:modified . l:filename . l:readonly
endfunction

function! LightlineFileinfo() abort
	let l:filetype = &filetype ==# '' ? 'no ft' : &filetype . ' '
	\	. WebDevIconsGetFileTypeSymbol()

	let l:fileformat = &fileformat . ' ' . WebDevIconsGetFileFormatSymbol()
	let l:fileencoding = &fileencoding ==# '' ? &encoding : &fileencoding

	let l:info = [ l:filetype, l:fileencoding, l:fileformat ]
	return lightline#concatenate(l:info, 1)
endfunction

