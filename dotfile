#!/usr/bin/env sh

# flags
DRY_RUN=0
VERBOSE=0
SKIP_DEPS=0

# Dotfiles root directory
dotfiles_root=$(cd "$(dirname "$0")" && pwd)

# Log functions
_error() {                         printf '\033[31m[ERROR]\033[0m dotfile: %s\n' "$*" >&2; }
_warn()  { [ "$VERBOSE" -eq 1 ] && printf '\033[33m[WARN]\033[0m dotfile: %s\n'  "$*" >&2; }
_info()  { [ "$VERBOSE" -eq 1 ] && printf '\033[32m[INFO]\033[0m dotfile: %s\n'  "$*" >&2; }

# Target install directories
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}"
data_dir="${XDG_DATA_HOME:-$HOME/.local/share}"
home_dir="$HOME"

# Create target directories if they don't exist
for target_dir in "$config_dir" "$data_dir"; do
    [ -d "$target_dir" ] || mkdir -p "$target_dir"
done


##
## Utilities functions
##

_collect_dotfiles() {
    for target in config data home; do
        base="$dotfiles_root/$target"
        [ -d "$base" ] || continue

        for path in "$base"/*/; do
            [ -d "$path" ] || continue
            name=${path%/}
            name=${name##*/}
            printf '%s\n' "$name"
        done
    done | sort -u
}

# Resolve the install directory path for a given target name
_target_dir() {
    case "$1" in
        config) printf '%s' "$config_dir" ;;
        data)   printf '%s' "$data_dir"   ;;
        home)   printf '%s' "$home_dir"   ;;
        *) _error "unknown target: $1"; return 1 ;;
    esac
}

# Dispatch install/uninstall
_do_action() {
    action="$1"
    source="$2"
    target="$3"

    if [ "$VERBOSE" -eq 1 ] || [ "$DRY_RUN" -eq 1 ]; then
        _info "$action: $source -> $target"
    fi

    [ "$DRY_RUN" -eq 1 ] && return 0
    case "$action" in
        install)
            [ -L "$target" ] && return 1
            ln -sf "$source" "$target"
            ;;
        uninstall)
            [ ! -L "$target" ] && return 1
            rm -f "$target"
            ;;
        *)
            _error "unknown action: $action"
            return 1
            ;;
    esac
}

_post_install_generate_colors() {
    dotfile="$1"
    scripter="$dotfiles_root/scripts/_scripter"

    [ -x "$scripter" ] || return 0
    "$scripter" color-reloader has "$dotfile" >/dev/null 2>&1 || return 0

    _info "generating colors for $dotfile..."
    "$scripter" color-reloader generate "$dotfile" >/dev/null 2>&1 || true
}


##
## Script commands
##

_cmd_action() {
    action="$1"; shift

    if [ $# -eq 0 ]; then
        _warn "no dotfiles selected, using all..."
        set -- $(_collect_dotfiles)
    fi

    for dotfile; do
        [ "$VERBOSE" -eq 1 ] && _info "processing: $dotfile"
        if [ "$action" = "install" ] && [ "$SKIP_DEPS" -eq 0 ]; then
            if ! _cmd_check "$dotfile"; then
                continue
            fi
        fi

        found=0
        did_install=0
        for target in home config data; do
            dotfile_dir="$dotfiles_root/$target/$dotfile"
            [ -d "$dotfile_dir" ] || continue

            case "$target" in
                home)
                    target_path="$(_target_dir "$target")"
                    for file_path in "$dotfile_dir"/*; do
                        [ -e "$file_path" ] || continue
                        _do_action "$action" "$file_path" "$target_path/.${file_path##*/}"
                    done
                    ;;
                config | data)
                    target_path="$(_target_dir "$target")/$dotfile"
                    if _do_action "$action" "$dotfile_dir" "$target_path"; then
                        [ "$action" = "install" ] && did_install=1
                    fi
                    ;;
            esac

            found=1
        done

        if [ "$did_install" = "1" ] && [ "$DRY_RUN" -eq 0 ]; then
            _post_install_generate_colors "$dotfile"
        fi

        [ "$found" -eq 1 ] || \
            _warn "'$dotfile' doesn't exist! Skipping."
    done

    exit 0
}

_cmd_check() {
    _dep_reset() {
        dep_file=""
        dep_dotfile="$1"
    }

    req_cmd() {
        cmd="$1"
        msg="$2"

        command -v "$cmd" >/dev/null 2>&1 && return 0

        _error "[$dep_dotfile] missing command: $cmd"
        [ -n "$msg" ] && printf '  -> %s\n' "$msg" >&2

        return 1
    }

    opt_cmd() {
        cmd="$1"
        msg="$2"

        command -v "$cmd" >/dev/null 2>&1 && return 0

        _warn "[$dep_dotfile] suggested command: $cmd"
        [ "$VERBOSE" -eq 1 ] && [ -n "$msg" ] && printf '  -> %s\n' "$msg" >&2

        return 0
    }

    if [ $# -eq 0 ]; then
        _warn "no dotfiles selected, using all..."
        set -- $(_collect_dotfiles)
    fi

    rc=0
    for dotfile; do
        _dep_reset "$dotfile"
        _info "Checking dependencies for [$dotfile]..."

        if [ -f "$dotfiles_root/.depends/$dotfile" ]; then
            dep_file="$dotfiles_root/.depends/$dotfile"
        elif [ -f "$dotfiles_root/.depends/script/$dotfile" ]; then
            dep_file="$dotfiles_root/.depends/script/$dotfile"
        fi

        if [ -f "$dep_file" ]; then
            if ! . "$dep_file"; then
                _error "[$dotfile] dependency check failed"
                rc=1
            else
                _info "all [$dotfile] dependencies satisfied"
            fi
        else
            _info "no [$dotfile] dependency file"
        fi
    done

    return $rc
}

_cmd_list() {
    _check_status() {
        target="$1"
        status="$2"

        if [ -L "$target" ]; then
            case "$status" in
                uninstalled) printf 'partial installed' ;;
                none)        printf 'installed' ;;
                *)           printf '%s' "$status" ;;
            esac
        else
            case "$status" in
                installed) printf 'partial installed' ;;
                none)      printf 'uninstalled' ;;
                *)         printf '%s' "$status" ;;
            esac
        fi
    }

    largest_name=0
    dotfiles=""
    for dotfile in $(_collect_dotfiles); do
        status="none"

        for target in home config data; do
            dotfile_dir="$dotfiles_root/$target/$dotfile"
            [ -d "$dotfile_dir" ] || continue

            case "$target" in
                home)
                    for file_path in "$dotfile_dir"/*; do
                        file=${file_path##*/}
                        file=".$file"

                        target_path="$(_target_dir "$target")/$file"
                        status="$(_check_status "$target_path" "$status")"
                    done
                    ;;
                config | data)
                    dotfile_path="$(_target_dir "$target")/$dotfile"
                    status="$(_check_status "$dotfile_path" "$status")"
                    ;;
            esac
        done

        [ "${#dotfile}" -gt "$largest_name" ] && largest_name="${#dotfile}"
        dotfiles="${dotfiles}${dotfile}:${status}
"
    done

    _info "Available dotfiles:"
    while IFS=: read -r dotfile status; do
        [ -n "$dotfile" ] || continue

        printf '  · %-'"${largest_name}"'s' "$dotfile"
        case "$status" in
            installed)           printf '\033[32m' ;;
            "partial installed") printf '\033[33m' ;;
        esac

        printf '   %s\033[0m\n' "$status"
    done <<EOF
$dotfiles
EOF
    printf '\n'
}

_cmd_help() {
    cat << 'EOF'
USAGE
    dotfile [options] <command> [ARGS...]

COMMANDS
    install [DOTFILES...]
        Install dotfiles to their target directories.
        If none specified, installs all.

    uninstall [DOTFILES...]
        Uninstall dotfiles.
        WARNING: If none specified, removes ALL.

    check [DOTFILES...]
        Check dependencies for dotfiles or scripts.
        If none specified, checks all.

    list
        Show dotfiles and installation status.

    help
        Show this help message.

OPTIONS
    -n, --dry-run
        Show actions without executing

    -s, --skip-deps
        Skip dependencies check

    -v, --verbose
        Enable verbose output

DESCRIPTION
    Dotfiles management system that installs configuration files and
    binaries to their appropriate XDG-compliant directories.

    Supported targets:
        • config     -> $XDG_CONFIG_HOME (default: $HOME/.config)
        • data       -> $XDG_DATA_HOME (default: $HOME/.local/share)
        • home       -> $HOME

EOF
}


##
## Parse arguments
##

[ $# -eq 0 ] && _cmd_help && exit 0

# parse options
while [ $# -gt 0 ]; do
    case "$1" in
        --dry-run|-n) DRY_RUN=1 ;;
        --verbose|-v) VERBOSE=1 ;;
        --skip-deps|-s)  SKIP_DEPS=1 ;;
        *) break ;;
    esac
    shift
done

# parse commands
while [ $# -gt 0 ]; do
    case "$1" in
        install | uninstall)
            _cmd_action "$@"
            ;;
        check)
            shift
            _cmd_check "$@"
            exit 0
            ;;
        list)
            _cmd_list
            exit 0
            ;;
        help)
            _cmd_help
            exit 0
            ;;
        *)
            _error "unknown command '$1'!"
            _cmd_help
            exit 1
            ;;
    esac
done

# vim: ft=sh
