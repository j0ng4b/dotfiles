#!/usr/bin/env sh

# Dotfiles root directory
dotfiles_root=$(cd "$(dirname "$0")" && pwd)

# Source common functions (error, warn, info, str_contains)
. "$dotfiles_root/scripts/_common"

# Target install directories
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}"
cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}"
data_dir="${XDG_DATA_HOME:-$HOME/.local/share}"
home_dir="$HOME"
bin_dir="$HOME/.local/bin"

# Create target directories if they don't exist
for target in config cache state data bin; do
    eval "target_dir=\$${target}_dir"
    [ -d "$target_dir" ] && continue
    mkdir -p "$target_dir"
done

# Resolve the install directory path for a given target name
_target_dir() {
    case "$1" in
        config) printf '%s' "$config_dir" ;;
        cache)  printf '%s' "$cache_dir"  ;;
        state)  printf '%s' "$state_dir"  ;;
        data)   printf '%s' "$data_dir"   ;;
        home)   printf '%s' "$home_dir"   ;;
        bin)    printf '%s' "$bin_dir"    ;;
        *) error "Unknown target: $1"; return 1 ;;
    esac
}

_get_dotfiles() {
    dotfiles=""
    for target in config data home; do
        [ -d "$dotfiles_root/$target" ] || continue
        for dotfile_path in "$dotfiles_root/$target"/*/; do
            [ -d "$dotfile_path" ] || continue
            dotfile=$(basename "$dotfile_path")
            [ "$dotfile" = "sources" ] && continue
            str_contains "$dotfiles" "$dotfile" || dotfiles="$dotfile $dotfiles"
        done
    done
    printf '%s' "$dotfiles"
}

_get_binaries() {
    binaries=""
    for binary_path in "$dotfiles_root/bin"/*; do
        [ -e "$binary_path" ] || continue
        binary=$(basename "$binary_path")
        [ "$binary" = "sources" ] && continue
        binaries="$binary $binaries"
    done
    printf '%s' "$binaries"
}

__install_dotfile() {
    [ -L "$1" ] && return 1
    ln -sfT "$2" "$1"
}

__uninstall_dotfile() {
    [ ! -L "$1" ] && return 1
    rm -f "$1"
}

# Dispatch install/uninstall without eval
_action() {
    case "$1" in
        install)   shift; __install_dotfile "$@" ;;
        uninstall) shift; __uninstall_dotfile "$@" ;;
        *) error "Unknown action: $1"; return 1 ;;
    esac
}

_dotfile_action_target_files() {
    action="$1"
    target="$2"
    dotfile="$3"
    dotfile_dir="$4"

    action_result_error=0
    for file_path in "$dotfile_dir"/*; do
        [ -e "$file_path" ] || continue
        file=$(basename "$file_path")

        # Files under the `home` target get a leading dot
        [ "$target" = "home" ] && file=".$file"

        file_target_path="$(_target_dir "$target")/$file"

        _action "$action" "$file_target_path" "$file_path"
        if [ $? -gt 0 ]; then
            action_result_error=1
            warn "\`$file\` of '$dotfile' already ${action}ed!"
        fi
    done

    return $action_result_error
}

_dotfile_action_bin() {
    action="$1"
    dotfile="$3"
    dotfile_path="$4"

    target_path="$(_target_dir bin)/$dotfile"

    _action "$action" "$target_path" "$dotfile_path"
    if [ $? -gt 0 ]; then
        warn "'bin/$dotfile' already ${action}ed!"
        return 1
    fi
}

_dotfile_action_target() {
    action="$1"
    target="$2"
    dotfile="$3"
    dotfile_dir="$4"

    dotfile_path="$(_target_dir "$target")/$dotfile"

    _action "$action" "$dotfile_path" "$dotfile_dir"
    if [ $? -gt 0 ]; then
        warn "\`$target\` of '$dotfile' already ${action}ed!"
        return 1
    fi
}

_dotfile_action() {
    action="$1"
    shift

    dotfiles="$*"
    if [ -z "$dotfiles" ]; then
        warn "Selecting all dotfiles..."
        dotfiles="$(_get_dotfiles)"
    fi

    for dotfile in $dotfiles; do
        if [ "$action" = "install" ]; then
            info "Installing $dotfile..."

            if ! str_contains "$dotfile" "bin/"; then
                info "Checking dependencies..."
                _check_dependencies "$dotfile" || continue
            fi
        else
            info "Uninstalling $dotfile..."
        fi

        # Handle bin/ dotfiles separately
        if str_contains "$dotfile" "bin/"; then
            if str_contains "$dotfile" "bin/sources"; then
                warn "The dotfile '$dotfile' is a source file! Skipping."
            else
                dotfile_name="${dotfile#bin/}"
                _dotfile_action_bin \
                    "$action" bin "$dotfile_name" "$dotfiles_root/bin/$dotfile_name"
            fi
            continue
        fi

        found_dotfile=0
        for target in home config data; do
            dotfile_dir="$dotfiles_root/$target/$dotfile"
            [ -d "$dotfile_dir" ] || continue

            case "$target" in
                home)          _dotfile_action_target_files "$action" "$target" "$dotfile" "$dotfile_dir" ;;
                config | data) _dotfile_action_target       "$action" "$target" "$dotfile" "$dotfile_dir" ;;
            esac

            found_dotfile=1
        done

        if [ "$found_dotfile" -eq 0 ]; then
            warn "The dotfile '$dotfile' doesn't exist! Skipping."
        # elif [ "$action" = "install" ]; then
        #     info "Generating colors..."
        #     sh "$dotfiles_root/scripts/_scripter" color-reloader --generate-only \
        #         "$dotfile" >/dev/null
        fi
    done

    exit 0
}

_check_dependencies() {
    descs=""
    desc()  { descs="$*"; }
    desca() { descs="${descs}:$*"; }

    cmd() {
        if ! command -v "$1" >/dev/null 2>&1; then
            error "The command '$1' is required by '$dotfile'"
            printf 'Why:\n'
            IFS=':'
            for description in $descs; do
                printf '  - %s\n' "$description"
            done
            unset IFS
            missing=1
        fi
    }

    opt() {
        if ! command -v "$1" >/dev/null 2>&1; then
            warn "You may want to install '$1' for '$dotfile'"
            printf 'Why:\n'
            IFS=':'
            for description in $descs; do
                printf '  - %s\n' "$description"
            done
            unset IFS
        fi
    }

    dotfiles="$*"
    if [ -z "$dotfiles" ]; then
        warn "Selecting all dotfiles..."
        dotfiles="$(_get_dotfiles)"
    fi

    for dotfile in $dotfiles; do
        [ "$dotfile" = "sysconf" ] && continue

        # Reset per-dotfile so a previous failure doesn't bleed into the next
        missing=0

        if ! str_contains "$dotfile" "script"; then
            desc "The dotfile requires the command it configures"
            cmd "$dotfile"

            if [ "$missing" -eq 1 ]; then
                error "Missing the command that '$dotfile' configures"
                continue
            fi
        elif [ "$dotfile" = "scripts" ]; then
            for script in "$dotfiles_root/.depends/script"/*; do
                [ -f "$script" ] || continue
                info "Checking dependencies for $(basename "$script")..."
                . "$script"
            done

            if [ "$missing" -eq 0 ]; then
                info "All $dotfile dependencies are satisfied."
            else
                error "Some dependencies are missing for some script."
                return 1
            fi

            continue
        fi

        if [ -f "$dotfiles_root/.depends/$dotfile" ]; then
            . "$dotfiles_root/.depends/$dotfile"
        fi

        if [ "$missing" -eq 0 ]; then
            info "All '$dotfile' dependencies are satisfied."
        else
            error "Some dependencies are missing for '$dotfile'."
            return 1
        fi
    done

    return 0
}

_list_dotfiles() {
    _check_status() {
        if [ -L "$1" ]; then
            case "$2" in
                uninstalled) printf 'partial installed' ;;
                none)        printf 'installed' ;;
                *)           printf '%s' "$2" ;;
            esac
        else
            case "$2" in
                installed) printf 'partial installed' ;;
                none)      printf 'uninstalled' ;;
                *)         printf '%s' "$2" ;;
            esac
        fi
    }

    _show_entries() {
        IFS=';'
        for entry in $1; do
            dotfile=$(printf '%s' "$entry" | cut -d: -f1)
            status=$(printf '%s' "$entry"  | cut -d: -f2)

            printf '  · %-'"${largest_name}"'s' "$dotfile"

            [ "$status" = "installed" ]         && printf '\033[32m'
            [ "$status" = "partial installed" ] && printf '\033[33m'

            printf '   %s\033[0m\n' "$status"
        done
        unset IFS
    }

    dotfile_entries=""
    largest_name=0
    for dotfile in $(_get_dotfiles); do
        install_level="none"

        for target in home config data; do
            dotfile_dir="$dotfiles_root/$target/$dotfile"
            [ -d "$dotfile_dir" ] || continue

            case "$target" in
                home)
                    for file_path in "$dotfile_dir"/*; do
                        [ -e "$file_path" ] || continue

                        file=$(basename "$file_path")
                        [ "$target" = "home" ] && file=".$file"

                        file_target_path="$(_target_dir "$target")/$file"
                        install_level=$(_check_status "$file_target_path" "$install_level")
                    done
                    ;;
                config | data)
                    dotfile_path="$(_target_dir "$target")/$dotfile"
                    install_level=$(_check_status "$dotfile_path" "$install_level")
                    ;;
            esac
        done

        [ "${#dotfile}" -gt "$largest_name" ] && largest_name="${#dotfile}"
        dotfile_entries="${dotfile}:${install_level};${dotfile_entries}"
    done

    binary_entries=""
    largest_name=0
    for binary in $(_get_binaries); do
        file_path="$bin_dir/$binary"
        install_level=$(_check_status "$file_path" "none")
        [ "${#binary}" -gt "$largest_name" ] && largest_name="${#binary}"
        binary_entries="${binary}:${install_level};${binary_entries}"
    done

    info "Available dotfiles:"
    _show_entries "$dotfile_entries"
    printf '\n'
    info "Available binaries:"
    _show_entries "$binary_entries"
}

[ $# -eq 0 ] && exit 1

while [ $# -gt 0 ]; do
    case "$1" in
        install | uninstall)
            _dotfile_action "$@"
            ;;
        check)
            shift
            _check_dependencies "$@"
            exit 0
            ;;
        list)
            _list_dotfiles
            exit 0
            ;;
        *)
            error "Unknown command: $1"
            exit 1
            ;;
    esac
done

# vim: ft=sh
