#!/usr/bin/env sh

# Constants
CONFIG_HOME=${XDG_CONFIG_HOME:-$HOME/.config}

# Create theme file if not exists
theme_dir="$CONFIG_HOME/sysconf"
theme_filename="theme"
theme_filepath="$theme_dir/$theme_filename"
[ ! -e "$theme_filepath" ] && echo "catppuccin/${COLOR_MODE:-dark}" > "$theme_filepath"

# Enabled re-loaders
registry_dir="$SCRIPT_CACHE_DIR"
registry_filename="reloaders"
registry_filepath="$registry_dir/$registry_filename"
daemon_pidfile="$registry_dir/daemon.pid"

pending_filename="reloaders_pending"
pending_filepath="$registry_dir/$pending_filename"

mkdir -p "$theme_dir" "$registry_dir"

# States
RELOADERS=""
WM_BACKENDS=""


##
## Utility functions
##

_get_theme_name() {
    [ -f "$theme_filepath" ] || return 1
    head -n1 "$theme_filepath" | tr -d '\r\n'
}

_register_reloader() {
    RELOADERS="${RELOADERS:+$RELOADERS }$1"
}

_validate_reloader() {
    if [ -z "$1" ]; then
        return 1
    fi

    for reloader in $RELOADERS; do
        [ "$reloader" = "$1" ] && return 0
    done

    return 1
}

_register_wm_backend() {
    WM_BACKENDS="${WM_BACKENDS:+$WM_BACKENDS }$1"
}

_validate_wm() {
    if [ -z "$1" ]; then
        return 1
    fi

    for wm_backend in $WM_BACKENDS; do
        [ "$wm_backend" = "$1" ] && return 0
    done

    return 1
}

_generate_colors_file() {
    template_name="$1"
    output_path="$2"
    theme_name="$(_get_theme_name)"

    theme="$root/color_reloader/color/$theme_name"
    if [ ! -f "$theme" ]; then
        fallback="$root/color_reloader/color/${theme_name%/*}/dark"
        if [ -f "$fallback" ]; then
            warn "color-reloader: fallback to dark mode"
            theme="$fallback"
        else
            error "color-reloader: theme not found: '$theme_name'"
            return 1
        fi
    fi

    template="$root/color_reloader/template/$template_name"
    [ -f "$template" ] || {
        warn "color-reloader: no template found for '$template_name'"
        return 1
    }

    # Generate color file
    mkdir -p "$(dirname "$output_path")"
    cp --force "$template" "$output_path"

    # build sed args safely
    set --
    while read -r color value; do
        [ -z "$color" ] && continue
        set -- "$@" -e "s|{$color}|$value|g"
    done < "$theme"
    sed "$@" "$output_path" > "$output_path.tmp" && mv "$output_path.tmp" "$output_path"
}


##
## Foot terminal
##

# Reload colors for all foot terminals
_foot_broadcast() {
    seqs_file="$1"

    for pts in /dev/pts/*; do
        [ -w "$pts" ] || continue
        cat "$seqs_file" > "$pts" 2>/dev/null
    done
}

_register_reloader foot
_foot_reloader() {
    colors_output_path="$CONFIG_HOME/foot/colors.ini"
    _cmd_generate --template foot --path "$colors_output_path" || return
    [ "$GENERATE_ONLY" = "1" ] && return

    seqs_file="$SCRIPT_CACHE_DIR/foot_seqs"
    : > "$seqs_file"

    sed -nr 's/.*(regular|bright)([0-9])\s*=\s*([a-zA-Z0-9]{6}).*/\1 \2 \3/p' "$colors_output_path" |
        while read -r type num color; do
            [ "$type" = "bright" ] && num=$(( num + 8 ))
            printf '\033]4;%d;#%s\a' "$num" "$color"
        done >> "$seqs_file"

    fg=$(sed -nr 's/.*foreground\s*=\s*([a-zA-Z0-9]{6}).*/\1/p' "$colors_output_path")
    [ -n "$fg" ] && printf '\033]10;#%s\a' "$fg" >> "$seqs_file"

    bg=$(sed -nr 's/.*background\s*=\s*([a-zA-Z0-9]{6}).*/\1/p' "$colors_output_path")
    [ -n "$bg" ] && printf '\033]11;#%s\a' "$bg" >> "$seqs_file"

    _foot_broadcast "$seqs_file"
}


##
## Reloaders
##

_register_reloader cava
_cava_reloader() {
    _cmd_generate --template cava --path "$CONFIG_HOME/cava/config" || return
    [ "$GENERATE_ONLY" = "1" ] || pkill -USR1 cava
}

_register_reloader btop
_btop_reloader() {
    _cmd_generate --template btop --path "$CONFIG_HOME/btop/themes/generated.theme" || return
    [ "$GENERATE_ONLY" = "1" ] || pkill -USR2 btop
}

_register_reloader bat
_bat_reloader() {
    _cmd_generate --template bat --path "$CONFIG_HOME/bat/themes/colors.tmTheme" || return
    bat cache --build >/dev/null
}

_register_reloader git
_git_reloader() {
    _cmd_generate --template git --path "$CONFIG_HOME/git/colors.gitconfig" || return
    # bat reloader is required to run
}

_register_reloader nvim
_nvim_reloader() {
    [ "$GENERATE_ONLY" = "1" ] && return
    theme_name="$(_get_theme_name)"

    for sock in "${XDG_RUNTIME_DIR}"/nvim.*.0; do
        [ -e "$sock" ] || continue
        nvim --clean --headless --server "$sock" \
            --remote-send \
                "<Cmd>lua require('core.theme').apply('$theme_name', true)<CR>" \
            2>/dev/null
    done
}

_register_reloader tmux
_tmux_reloader() {
    _cmd_generate --template shell --path "$CONFIG_HOME/tmux/colors.tmux" || return
    [ "$GENERATE_ONLY" = "1" ] || tmux run-shell "$CONFIG_HOME/tmux/style.tmux"
}

_register_reloader starship
_starship_reloader() {
    _cmd_generate --template starship --path "$CONFIG_HOME/starship/config.toml" || return
    [ "$GENERATE_ONLY" = "1" ] || pkill -USR1 zsh
}

_register_reloader quickshell
_quickshell_reloader() {
    _cmd_generate --template quickshell --path "$CONFIG_HOME/shell/colors.json" || return
    # nothing to do, quickshell will auto reload colors anyway
}


##
## Window Manager
##

_detect_wm() {
    xdg="$(printf '%s:%s' "$XDG_CURRENT_DESKTOP" "$XDG_SESSION_DESKTOP" | tr '[:upper:]' '[:lower:]')"
    for wm in niri mango; do
        case "$xdg" in
            *"$wm"*) echo "$wm"; return ;;
        esac

        pgrep -x "$wm" >/dev/null && {
            echo "$wm"
            return
        }
    done

    return 1
}

_register_wm_backend niri
_wm_backend_niri() {
    _cmd_generate --template niri --path "$CONFIG_HOME/niri/colors.kdl" || return
    # automatic reload for niri - no action needed
}

_register_wm_backend mango
_wm_backend_mango() {
    _cmd_generate --template mango --path "$CONFIG_HOME/mango/colors.conf" || return
    [ "$GENERATE_ONLY" = "1" ] || mmsg -d reload_config
}

_register_reloader wm
_wm_reloader() {
    wm="$(_detect_wm)"

    if [ -z "$wm" ]; then
        warn "color-reloader: no window manager detected"
        return
    fi

    info "color-reloader: detected WM = $wm"

    if _validate_wm "$wm"; then
        "_wm_backend_${wm}" 2>/dev/null
    else
        warn "color-reloader: no backend for WM '$wm', using default"
    fi
}


##
## Helpers
##

_run_reloader() {
    [ "$GENERATE_ONLY" = "1" ] || info "color-reloader: reloading $1"
    "_${1}_reloader"
}

_run_all() {
    [ ! -f "$registry_filepath" ] && return
    while IFS= read -r name; do
        [ -z "$name" ] && continue
        _run_reloader "$name" &
    done < "$registry_filepath"
    wait
}

_daemon_running() {
    [ -f "$daemon_pidfile" ] || return 1
    pid=$(cat "$daemon_pidfile")
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}


##
## Script commands
##

_cmd_run() {
    if _daemon_running; then
        info "color-reloader: daemon already running, registering reloaders only"
        _cmd_register "$@"
        return
    fi

    # Register initial re-loaders set
    for name in "$@"; do
        _validate_reloader "$name" || continue
        grep -qxF "$name" "$registry_filepath" 2>/dev/null \
            || echo "$name" >> "$registry_filepath"
    done
    _run_all

    command -v inotifywait >/dev/null 2>&1 || {
        error "color-reloader: inotifywait not found"
        exit 1
    }

    # Register current process pid
    echo $$ > "$daemon_pidfile"
    trap 'rm -f "$daemon_pidfile"' EXIT INT TERM

    info "color-reloader: running daemon (pid $$)"
    while true; do
        changed=$(inotifywait --quiet \
            --event close_write \
            --event moved_to \
            --format '%f' \
            "$theme_dir" "$registry_dir" 2>/dev/null) || { sleep 1; continue; }

        if [ "$changed" = "$theme_filename" ]; then
            _run_all

        elif [ "$changed" = "$registry_filename" ] || [ "$changed" = "$pending_filename" ]; then
            [ ! -f "$pending_filepath" ] && continue
            pending="$(cat "$pending_filepath")"
            [ -z "$pending" ] && continue

            : > "$pending_filepath"

            printf '%s\n' "$pending" | while IFS= read -r name; do
                [ -z "$name" ] && continue
                _run_reloader "$name" &
            done
            wait
        fi
    done
}

_cmd_register() {
    for name in "$@"; do
        _validate_reloader "$name" || continue
        if grep -qxF "$name" "$registry_filepath" 2>/dev/null; then
            warn "color-reloader: '$name' already registered"
        else
            echo "$name" >> "$registry_filepath"
            echo "$name" >> "$pending_filepath"
            info "color-reloader: '$name' registered"
        fi
    done
}

_cmd_unregister() {
    for name in "$@"; do
        [ -f "$registry_filepath" ] || continue

        tmp="$registry_filepath.tmp"
        grep -vxF "$name" "$registry_filepath" > "$tmp" 2>/dev/null && mv "$tmp" "$registry_filepath"
        info "color-reloader: '$name' unregistered"
    done
}

_cmd_reload() {
    _run_all
}

_cmd_generate() {
    template=""
    output=""
    names=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -t|--template)
                [ -n "$2" ] || { error "--template requires argument"; return 1; }
                template="$2"
                shift 2
                ;;
            -p|--path)
                [ -n "$2" ] || { error "--path requires argument"; return 1; }
                output="$2"
                shift 2
                ;;
            --)
                shift
                names="$*"
                break
                ;;
            -*)
                error "color-reloader: invalid option '$1'"
                return 1
                ;;
            *)
                # first positional -> names mode
                names="$*"
                break
                ;;
        esac
    done

    ( [ -n "$template" ] || [ -n "$output" ] ) && [ -n "$names" ] && {
        error "cannot mix template mode with names"
        return 1
    }

    ##
    ## Mode: template
    ##
    if [ -n "$template" ] || [ -n "$output" ]; then
        [ -z "$template" ] && {
            error "color-reloader: --template required"
            return 1
        }

        [ -z "$output" ] && {
            error "color-reloader: --path required"
            return 1
        }

        _generate_colors_file "$template" "$output"
        return
    fi

    ##
    ## Mode: names
    ##
    [ -z "$names" ] && {
        warn "color-reloader: nothing selected, fallback to all registered"
        names="$(cat "$registry_filepath" 2>/dev/null)"
        detected_wm="$(_detect_wm)"
        [ -n "$detected_wm" ] && names="$names $detected_wm"
    }

    [ -z "$names" ] && {
        warn "color-reloader: nothing to generate"
        return 0
    }

    for name in $names; do
        if _validate_reloader "$name"; then
            info "color-reloader: generating $name colors"
            GENERATE_ONLY=1 _run_reloader "$name"
        elif _validate_wm "$name"; then
            info "color-reloader: generating $name colors"
            GENERATE_ONLY=1 "_wm_backend_${name}"
        else
            error "color-reloader: unknown reloader or wm backend '$name'"
        fi
    done
}

_cmd_status() {
    if _daemon_running; then
        pid=$(cat "$daemon_pidfile")
        printf '\033[32m●\033[0m daemon running \033[2m(pid %s)\033[0m\n\n' "$pid"
    else
        printf '\033[31m○\033[0m daemon stopped\n\n'
    fi

    largest_name=0
    for reloader in $RELOADERS; do
        [ "${#reloader}" -gt "$largest_name" ] && largest_name="${#reloader}"
    done

    info "Reloaders:"
    for reloader in $RELOADERS; do
        printf '  %-'"${largest_name}"'s  ' "$reloader"

        if grep -qxF "$reloader" "$registry_filepath" 2>/dev/null; then
            printf '\033[33mregistered\033[0m'
        else
            printf '\033[2munregistered\033[0m'
        fi

        printf '\n'
    done
    printf '\n'

    info "WM backends:"
    detected_wm="$(_detect_wm 2>/dev/null)"
    for backend in $WM_BACKENDS; do
        printf '  %s' "$backend"
        [ "$backend" = "$detected_wm" ] && printf '  \033[32m(active)\033[0m'
        printf '\n'
    done
    printf '\n'

    theme="$(_get_theme_name 2>/dev/null)"
    [ -n "$theme" ] && info "Current theme: $theme"
}

_cmd_has() {
    if _validate_reloader "$1"; then
        return 0
    else
        return 1
    fi
}

_cmd_help() {
    echo "Usage: scripter color-reloader <command> [reloaders...]"
    echo ""
    echo "Commands:"
    echo "  run         Run the color reloader daemon with specified reloaders"
    echo "  register    Register reloaders to be automatically reloaded on theme change"
    echo "  unregister  Unregister reloaders"
    echo "  reload      Manually trigger reload for all registered reloaders"
    echo "  generate    Generate color file for a given template and output path"
    echo "  status      Show informations about reloaders status"
    echo "  has         Check if some reloader is valid"
    echo "  help        Show this help message"
    echo ""
}

##
## Parse args
##

cmd=""
while [ $# -gt 0 ]; do
    case "$1" in
        run | register | unregister | reload | generate | status | has | help)
            cmd="$1"
            shift
            break
            ;;
        -*)
            error "color-reloader: invalid option '$1'!"
            _cmd_help
            exit 1
            ;;
        *)
            error "color-reloader: unknown command '$1'!"
            _cmd_help
            exit 1
            ;;
    esac
    shift
done

case "$cmd" in
    run)        _cmd_run "$@" ;;
    register)   _cmd_register "$@" ;;
    unregister) _cmd_unregister "$@" ;;
    reload)     _cmd_reload ;;
    generate)   _cmd_generate "$@" ;;
    status)     _cmd_status ;;
    has)        _cmd_has "$1" ;;
    help)       _cmd_help ;;
esac

# vim: ft=sh
