#!/usr/bin/env sh

# Flags
GENERATE_ONLY=0

# Create theme file if not exists
theme_dir="${XDG_CONFIG_HOME:-$HOME/.config}/sysconf"
theme_filename="theme"
theme_filepath="$theme_dir/$theme_filename"
[ ! -e "$theme_filepath" ] && echo "catppuccin" > "$theme_filepath"

# Enabled re-loaders
registry_dir="$SCRIPT_CACHE_DIR"
registry_filename="reloaders"
registry_filepath="$registry_dir/$registry_filename"

pending_filename="reloaders_pending"
pending_filepath="$registry_dir/$pending_filename"

mkdir -p "$theme_dir" "$registry_dir"

# States
RELOADERS=""
WM_BACKENDS=""


##
## Utility functions
##

_get_theme_name() {
    echo "$(tr -d '\n' < "$theme_filepath")"
}

_register_reloader() {
    RELOADERS="$RELOADERS $1"
}

_validate_reloader() {
    if str_contains "$RELOADERS" "$1"; then
        return 0
    fi

    error "color-reloader: unknown reloader '$1'"
    return 1
}

_register_wm_backend() {
    WM_BACKENDS="$WM_BACKENDS $1"
}

_validate_wm() {
    if [ -z "$1" ]; then
        return 1
    fi

    if str_contains "$WM_BACKENDS" "$1"; then
        return 0
    fi

    return 1
}

__generate_colors_file() {
    template_name="$1"
    output_path="$2"
    theme_name="$(_get_theme_name)"

    if [ ! -e "$root/color_reloader/template/$template_name" ]; then
        warn "color-reloader: no template found for '$template_name'"
        return 1
    fi

    if [ ! -e "$root/color_reloader/color/$theme_name" ]; then
        error "color-reloader: theme not found: '$theme_name'"
        return 1
    fi

    . "$root/color_reloader/color/$theme_name"
    mkdir -p "$(dirname "$output_path")"

    # Generate color file
    cp --force "$root/color_reloader/template/$template_name" "$output_path"
    for color in base00 base01 base02 base03 base04 base05 base06 base07 \
                 base08 base09 base0A base0B base0C base0D base0E base0F; do
        eval "sed -i \"s/{$color}/\${$color}/g\" \"$output_path\""
    done
}


##
## Foot terminal
##

# Reload colors for all foot terminals
_foot_broadcast() {
    seqs_file="$1"

    for pts in /dev/pts/*; do
        [ -w "$pts" ] || continue
        cat "$seqs_file" > "$pts" 2>/dev/null
    done
}

_register_reloader foot
_foot_reloader() {
    colors_output_path="${XDG_CONFIG_HOME:-$HOME/.config}/foot/colors.ini"
    __generate_colors_file foot "$colors_output_path" || return

    seqs_file="$SCRIPT_CACHE_DIR/foot_seqs"
    : > "$seqs_file"

    sed -nr 's/.*(regular|bright)([0-9])\s*=\s*([a-zA-Z0-9]{6}).*/\1 \2 \3/p' "$colors_output_path" |
        while read -r type num color; do
            [ "$type" = "bright" ] && num=$(( num + 8 ))
            printf '\033]4;%d;#%s\a' "$num" "$color"
        done >> "$seqs_file"

    fg=$(sed -nr 's/.*foreground\s*=\s*([a-zA-Z0-9]{6}).*/\1/p' "$colors_output_path")
    [ -n "$fg" ] && printf '\033]10;#%s\a' "$fg" >> "$seqs_file"

    bg=$(sed -nr 's/.*background\s*=\s*([a-zA-Z0-9]{6}).*/\1/p' "$colors_output_path")
    [ -n "$bg" ] && printf '\033]11;#%s\a' "$bg" >> "$seqs_file"

    _foot_broadcast "$seqs_file"
}


##
## Reloaders
##

_register_reloader cava
_cava_reloader() {
    colors_output_path="${XDG_CONFIG_HOME:-$HOME/.config}/cava/config"
    __generate_colors_file cava "$colors_output_path" || return

    pkill -USR1 cava
}

_register_reloader btop
_btop_reloader() {
    colors_output_path="${XDG_CONFIG_HOME:-$HOME/.config}/btop/themes/generated.theme"
    __generate_colors_file btop "$colors_output_path" || return
    pkill -USR2 btop
}

_register_reloader bat
_bat_reloader() {
    colors_output_path="${XDG_CONFIG_HOME:-$HOME/.config}/bat/themes/colors.tmTheme"
    __generate_colors_file bat "$colors_output_path" || return
    bat cache --build >/dev/null
}

_register_reloader git
_git_reloader() {
    colors_output_path="${XDG_CONFIG_HOME:-$HOME/.config}/git/colors.gitconfig"
    __generate_colors_file git "$colors_output_path" || return

    # Also require bat colors
    _bat_reloader
}

_register_reloader nvim
_nvim_reloader() {
    theme_name="$(_get_theme_name)"

    for sock in "${XDG_RUNTIME_DIR}"/nvim.*.0; do
        [ -e "$sock" ] || continue
        nvim --clean --headless --server "$sock" \
            --remote-send \
                "<Cmd>if get(g:, 'colors_name', '') !=# '$theme_name' |\
                    let g:_update_colorscheme=1                       |\
                    silent! colorscheme $theme_name                   |\
                endif<CR>" +'qa!' 2>/dev/null
    done
}

_register_reloader tmux
_tmux_reloader() {
    colors_output_path="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/colors.tmux"
    __generate_colors_file shell "$colors_output_path" || return
    tmux run-shell "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/style.tmux"
}

_register_reloader starship
_starship_reloader() {
    colors_output_path="${XDG_CONFIG_HOME:-$HOME/.config}/starship/config.toml"
    __generate_colors_file starship "$colors_output_path" || return

    pkill -USR1 zsh # reload config
    pkill -WINCH zsh # force redraw
}


##
## Window Manager
##

_detect_wm() {
    xdg="$(printf '%s' "$XDG_CURRENT_DESKTOP" | tr '[:upper:]' '[:lower:]')"
    session="$(printf '%s' "$XDG_SESSION_DESKTOP" | tr '[:upper:]' '[:lower:]')"

    wm=""

    # try detect using XDG_CURRENT_DESKTOP
    case "$xdg" in
        *niri*) wm="niri" ;;
        *mango*) wm="mango" ;;
        *)        ;;
    esac
    [ -n "$wm" ] && echo "$wm" && return

    # try detect using session
    case "$session" in
        niri) wm="niri" ;;
        mango) wm="mango" ;;
    esac
    [ -n "$wm" ] && echo "$wm" && return

    # as fallback try detect using running process
    for wm in niri mango; do
        if pgrep -x "$wm" >/dev/null; then
            echo "$wm"
            return
        fi
    done

    echo ""
}

_register_wm_backend niri
_wm_backend_niri() {
    colors_output_path="${XDG_CONFIG_HOME:-$HOME/.config}/niri/colors.kdl"
    __generate_colors_file niri "$colors_output_path"
    # automatic reload for niri - no action needed
}

_register_wm_backend mango
_wm_backend_mango() {
    colors_output_path="${XDG_CONFIG_HOME:-$HOME/.config}/mango/colors.conf"
    __generate_colors_file mango "$colors_output_path"
    mmsg -d reload_config
}

_register_reloader wm
_wm_reloader() {
    wm="$(_detect_wm)"

    if [ -z "$wm" ]; then
        warn "color-reloader: no window manager detected"
        _wm_backend_default
        return
    fi

    info "color-reloader: detected WM = $wm"

    if _validate_wm "$wm"; then
        "_wm_backend_${wm}" 2>/dev/null
    else
        warn "color-reloader: no backend for WM '$wm', using default"
    fi
}


##
## Utility functions
##

_run_reloader() {
    name="$1"
    info "color-reloader: reloading $name"
    "_${name}_reloader"
}

_run_all() {
    [ ! -f "$registry_filepath" ] && return
    while IFS= read -r name; do
        [ -z "$name" ] && continue
        _run_reloader "$name" &
    done < "$registry_filepath"
    wait
}

_usage() {
    echo "Usage: scripter color-reloader [options] <command> [reloaders...]"
    echo ""
    echo "Commands:"
    echo "  run         Run the color reloader daemon with specified reloaders"
    echo "  register    Register reloaders to be automatically reloaded on theme change"
    echo "  unregister  Unregister reloaders"
    echo "  reload      Manually trigger reload for all registered reloaders"
    echo "  list        List available reloaders"
    echo "  help        Show this help message"
    echo ""
    echo "Options:"
    echo "  -g, --generate-only  Only generate color files without running the daemon"
}


##
## Script commands
##

_cmd_run() {
    # Register initial re-loaders set
    for name in "$@"; do
        _validate_reloader "$name" || continue
        grep -qxF "$name" "$registry_filepath" 2>/dev/null \
            || echo "$name" >> "$registry_filepath"
    done

    _run_all
    [ "$GENERATE_ONLY" -eq 1 ] && return 0

    command -v inotifywait >/dev/null 2>&1 || {
        error "color-reloader: inotifywait not found"
        exit 1
    }

    info "color-reloader: running daemon"
    while true; do
        changed=$(inotifywait --quiet \
            --event close_write \
            --event moved_to \
            --format '%f' \
            "$theme_dir" "$registry_dir" 2>/dev/null)

        if [ "$changed" = "$theme_filename" ]; then
            _run_all

        elif [ "$changed" = "$registry_filename" ] || [ "$changed" = "$pending_filename" ]; then
            [ ! -f "$pending_filepath" ] && continue
            pending="$(cat "$pending_filepath")"
            [ -z "$pending" ] && continue

            : > "$pending_filepath"

            printf '%s\n' "$pending" | while IFS= read -r name; do
                [ -z "$name" ] && continue
                _run_reloader "$name" &
            done
            wait
        fi
    done
}

_cmd_register() {
    for name in "$@"; do
        _validate_reloader "$name" || continue
        if grep -qxF "$name" "$registry_filepath" 2>/dev/null; then
            warn "color-reloader: '$name' already registered"
        else
            echo "$name" >> "$registry_filepath"
            echo "$name" >> "$pending_filepath"
            info "color-reloader: '$name' registered"
        fi
    done
}

_cmd_unregister() {
    for name in "$@"; do
        sed -i "/^${name}$/d" "$registry_filepath" 2>/dev/null
        info "color-reloader: '$name' unregistered"
    done
}

_cmd_reload() {
    _run_all
}

_cmd_list() {
    largest_name=0
    for reloader in $RELOADERS; do
        [ "${#reloader}" -gt "$largest_name" ] && largest_name="${#reloader}"
    done

    info "Available reloaders:"
    for reloader in $RELOADERS; do
        printf '  · %-'"${largest_name}"'s' "$reloader"

        if grep -qxF "$reloader" "$registry_filepath" 2>/dev/null; then
            printf '    \033[32mrunning\033[0m'
        else
            printf '    stopped'
        fi

        [ "$reloader" = "wm" ] && printf ' [%s]' "$(_detect_wm)"
        printf '\n'
    done
}


##
## Parse args
##

cmd=""
while [ $# -gt 0 ]; do
    case "$1" in
        --generate-only | -g)
            GENERATE_ONLY=1
            ;;
        run | register | unregister | reload | list | help)
            cmd="$1"
            shift
            break
            ;;
        -*)
            error "color-reloader: invalid option '$1'!"
            _usage
            exit 1
            ;;
        *)
            error "color-reloader: unknown command '$1'!"
            _usage
            exit 1
            ;;
    esac
    shift
done

case "$cmd" in
    run)        _cmd_run "$@" ;;
    register)   _cmd_register "$@" ;;
    unregister) _cmd_unregister "$@" ;;
    reload)     _cmd_reload ;;
    list)       _cmd_list ;;
    help)
        _usage
        ;;
    *)
        _usage
        exit 1
        ;;
esac

# vim: ft=sh
