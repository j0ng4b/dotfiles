#!/usr/bin/env sh

# Cache
cache_dir="$SCRIPT_CACHE_DIR"

cache_dir_wifi="$cache_dir/wifi"
cache_wifi_interface="$cache_dir_wifi/interface"
cache_wifi_power="$cache_dir_wifi/power"
cache_wifi_signal_level="$cache_dir_wifi/signal_level"

if [ -z "$cache_dir" ]; then
    exit 1
elif [ ! -d "$cache_dir" ]; then
    mkdir -p "$cache_dir_wifi"

    # WiFi
    touch "$cache_wifi_signal_level"
    touch "$cache_wifi_power"
    interface=$(find /sys/class/net \( -name "wlan*" -o -name "wl*" \) -exec basename {} \; | head -1)
    [ -n "$interface" ] && echo "$interface" > "$cache_wifi_interface"

    for i in $(seq 1 5); do
        echo -50 >> "$cache_wifi_signal_level"
    done
fi

##
## Backend detection
##

_detect_wifi_backend() {
    if command -v nmcli >/dev/null 2>&1; then echo "nmcli"
    elif command -v iwctl >/dev/null 2>&1; then echo "iwctl"
    elif command -v wpa_cli >/dev/null 2>&1; then echo "wpa"
    else echo "none"
    fi
}

_wifi_op() {
    op="$1"; shift
    "_wifi_${op}_${wifi_backend}" "$@"
}

_wifi_interface() {
    if [ -f "$cache_wifi_interface" ]; then
        cat "$cache_wifi_interface"
    else
        find /sys/class/net \( -name "wlan*" -o -name "wl*" \) -exec basename {} \; | head -1
    fi
}


##
## WiFi — nmcli backend
##

_wifi_status_nmcli() {
    iface="$(_wifi_interface)"
    [ -z "$iface" ] && echo '{"enable": 0, "state": "unknown"}' && return

    connected=$(nmcli -g GENERAL.STATE device show "$iface" 2>/dev/null | grep -c "connected")

    if [ "$connected" -eq 0 ]; then
        echo '{"enable": 0, "state": "unknown"}'
        return
    fi

    name=$(nmcli -g GENERAL.CONNECTION device show "$iface" 2>/dev/null)
    signal=$(nmcli -g IN-USE,SIGNAL device wifi list ifname "$iface" 2>/dev/null | \
        grep '^\*' | head -1 | cut -d: -f2)
    signal_level=$(( -100 + signal / 2 ))

    _net_check_connection && state="noconnection" || state="connected"

    printf '{"enable": 1, "state": "%s", "signal_level": %d, "name": "%s"}\n' \
        "$state" "$signal_level" "$name"
}

_wifi_list_nmcli() {
    iface="$(_wifi_interface)"
    nmcli -g IN-USE,SSID,SIGNAL,SECURITY device wifi list ifname "$iface" 2>/dev/null | \
    while IFS=: read -r inuse ssid signal security; do
        [ -z "$ssid" ] && continue
        current='false'
        [ "$inuse" = "*" ] && current='true'
        saved='false'
        nmcli -g NAME connection show 2>/dev/null | grep -qxF "$ssid" && saved='true'
        signal_level=$(( -100 + signal / 2 ))
        printf '%d|%s|%s|%s|%s\n' "$signal_level" "$ssid" "$current" "$security" "$saved"
    done | sort -t'|' -k1 -rn
}

_wifi_list_saved_nmcli() {
    nmcli -g NAME,TYPE connection show | grep wireless | cut -d: -f1 | \
    while read -r ssid; do
        printf '{"ssid": "%s", "saved": true}\n' "$ssid"
    done
}

_wifi_connect_nmcli() {
    ssid="$1"
    password="$2"

    if nmcli -g NAME connection show 2>/dev/null | grep -qxF "$ssid"; then
        nmcli connection up "$ssid" >/dev/null
    elif [ -n "$password" ]; then
        nmcli device wifi connect "$ssid" password "$password" >/dev/null
    else
        return 1
    fi
}

_wifi_disconnect_nmcli() {
    iface="$(_wifi_interface)"
    nmcli device disconnect "$iface" >/dev/null
}

_wifi_forget_nmcli() {
    ssid="$1"
    [ -z "$ssid" ] && error "network: no SSID provided" && return 1
    nmcli connection delete "$ssid" >/dev/null
    info "network: forgot '$ssid'"
}

_wifi_power_nmcli() {
    nmcli radio wifi "$1" >/dev/null
    echo "$1" > "$cache_wifi_power"
}


##
## WiFi — iwctl backend
##

_wifi_status_iwctl() {
    iface="$(_wifi_interface)"
    [ -z "$iface" ] && echo '{"enable": 0, "state": "unknown"}' && return

    iwctl_output=$(iwctl station "$iface" show 2>/dev/null)
    state_raw=$(echo "$iwctl_output" | sed -ne 's/.*State\s*\(.*\)/\1/p' | tr -d ' ')

    if [ "$state_raw" != "connected" ]; then
        echo '{"enable": 0, "state": "unknown"}'
        return
    fi

    name=$(echo "$iwctl_output" | sed '1,6d;8,$d;s/.*network\s*//;s/\s*$//')
    signal_level=$(echo "$iwctl_output" | sed -n '/AverageRSSI/s/.*\(-[0-9]*\).*/\1/p')

    _net_check_connection && state="noconnection" || state="connected"

    printf '{"enable": 1, "state": "%s", "signal_level": %d, "name": "%s"}\n' \
        "$state" "${signal_level:-0}" "$name"
}

_wifi_list_iwctl() {
    iface="$(_wifi_interface)"

    iwctl station "$iface" scan >/dev/null
    sleep 1

    saved_networks="|$(iwctl known-networks list \
        | sed -e '1,4d' -e 's/\x1b\[[0-9;]*m//g' -e 's/^[ \t]*//g' -e 's/[ ]\{3,\}.*$//' \
        | tr '\n' '|')"

    iwctl station "$iface" get-networks 2>/dev/null \
        | sed -e '1,4d' -e 's/\x1b\[[0-9;]*m//g' \
        | while IFS= read -r network; do
            [ -z "$network" ] && continue

            strength=$(echo "$network" | tr -s ' ' | sed -e 's/^[ \t>]*//' -e 's/^>* *//' | cut -d' ' -f3)
            [ -z "$strength" ] && continue

            case "$strength" in
                "****") signal_level="-50" ;;
                "***")  signal_level="-60" ;;
                "**")   signal_level="-75" ;;
                "*")    signal_level="-85" ;;
                *)      signal_level="-100" ;;
            esac

            current='false'
            echo "$network" | grep -q '>' && current='true'

            ssid=$(echo "$network" | sed -e 's/^[ \t>]*//' -e 's/[ ]\{3,\}.*$//')
            [ -z "$ssid" ] && continue

            security='open'
            case "$network" in
                *'   psk   '*)   security='wpa' ;;
                *'   8021x   '*) security='enterprise' ;;
            esac

            saved='false'
            str_contains "$saved_networks" "|$ssid|" && saved='true'

            echo "$signal_level|$ssid|$current|$security|$saved"
        done | sort -t'|' -k1 -rn
}

_wifi_list_saved_iwctl() {
    iwctl known-networks list | sed -e '1,4d' \
        -e 's/\x1b\[[0-9;]*m//g' \
        -e 's/^[ \t]*//' \
        -e 's/[ ]\{3,\}.*$//' | \
    while read -r ssid; do
        [ -z "$ssid" ] && continue
        printf '{"ssid": "%s", "saved": true}\n' "$ssid"
    done
}

_wifi_connect_iwctl() {
    ssid="$1"
    password="$2"
    iface="$(_wifi_interface)"

    if [ -n "$password" ]; then
        iwctl --passphrase "$password" station "$iface" connect "$ssid" >/dev/null
    else
        iwctl station "$iface" connect "$ssid" >/dev/null
    fi
}

_wifi_disconnect_iwctl() {
    iface="$(_wifi_interface)"
    iwctl station "$iface" disconnect >/dev/null
}

_wifi_forget_iwctl() {
    ssid="$1"
    [ -z "$ssid" ] && error "network: no SSID provided" && return 1
    iwctl known-networks "$ssid" forget >/dev/null
    info "network: forgot '$ssid'"
}

_wifi_power_iwctl() {
    iface="$(_wifi_interface)"
    iwctl device "$iface" set-property Powered "$1" >/dev/null
    echo "$1" > "$cache_wifi_power"
}


##
## WiFi — wpa backend
##

_wifi_status_wpa() {
    iface="$(_wifi_interface)"
    [ -z "$iface" ] && echo '{"enable": 0, "state": "unknown"}' && return

    wpa_state=$(wpa_cli -i "$iface" status 2>/dev/null | grep '^wpa_state=' | cut -d= -f2)

    if [ "$wpa_state" != "COMPLETED" ]; then
        echo '{"enable": 0, "state": "unknown"}'
        return
    fi

    name=$(wpa_cli -i "$iface" status 2>/dev/null | grep '^ssid=' | cut -d= -f2)
    signal_level=$(wpa_cli -i "$iface" signal_poll 2>/dev/null | grep '^RSSI=' | cut -d= -f2)

    _net_check_connection && state="noconnection" || state="connected"

    printf '{"enable": 1, "state": "%s", "signal_level": %d, "name": "%s"}\n' \
        "$state" "${signal_level:-0}" "$name"
}

_wifi_list_wpa() {
    iface="$(_wifi_interface)"
    temp_file=$(mktemp)

    wpa_cli -i "$iface" scan >/dev/null
    sleep 0.5

    wpa_cli -i "$iface" scan_results 2>/dev/null \
        | sed -ne '2,$s/.*\(-[0-9]*\)\s\+\[.*\]\s\+\(.*\)/\1|\2/p' \
        | while IFS='|' read -r signal ssid; do
            [ -z "$ssid" ] && continue
            current='false'
            wpa_cli -i "$iface" status 2>/dev/null | grep -q "^ssid=$ssid$" && current='true'
            saved='false'
            wpa_cli -i "$iface" list_networks 2>/dev/null | grep -q "$ssid" && saved='true'
            echo "$signal|$ssid|$current|open|$saved" >> "$temp_file"
        done

    sort -t'|' -k1 -rn "$temp_file"
    rm -f "$temp_file"
}

_wifi_list_saved_wpa() {
    iface="$(_wifi_interface)"
    wpa_cli -i "$iface" list_networks 2>/dev/null | sed -ne '2,$p' | \
    while IFS='	' read -r _ ssid _; do
        [ -z "$ssid" ] && continue
        printf '{"ssid": "%s", "saved": true}\n' "$ssid"
    done
}

_wifi_connect_wpa() {
    ssid="$1"
    password="$2"
    iface="$(_wifi_interface)"

    # Verifica se já está salva
    if wpa_cli -i "$iface" list_networks 2>/dev/null | grep -q "$ssid"; then
        id=$(wpa_cli -i "$iface" list_networks | grep "$ssid" | cut -f1)
        wpa_cli -i "$iface" select_network "$id" >/dev/null
        return
    fi

    [ -z "$password" ] && return 1

    _wifi_disconnect_wpa

    id=$(wpa_cli -i "$iface" add_network | tail -1)
    wpa_cli -i "$iface" set_network "$id" ssid "\"$ssid\"" >/dev/null
    wpa_cli -i "$iface" set_network "$id" psk "\"$password\"" >/dev/null
    wpa_cli -i "$iface" set_network "$id" priority 10 >/dev/null
    wpa_cli -i "$iface" enable_network "$id" >/dev/null
    wpa_cli -i "$iface" reconnect >/dev/null
    wpa_cli -i "$iface" save_config >/dev/null
}

_wifi_disconnect_wpa() {
    iface="$(_wifi_interface)"
    id=$(wpa_cli -i "$iface" list_networks 2>/dev/null \
        | grep '\[CURRENT\]' | cut -f1)
    [ -n "$id" ] && wpa_cli -i "$iface" disable_network "$id" >/dev/null
    wpa_cli -i "$iface" disconnect >/dev/null
}

_wifi_forget_wpa() {
    ssid="$1"
    iface="$(_wifi_interface)"
    [ -z "$ssid" ] && error "network: no SSID provided" && return 1

    id=$(wpa_cli -i "$iface" list_networks 2>/dev/null | grep "$ssid" | cut -f1)
    [ -z "$id" ] && error "network: '$ssid' not found" && return 1

    wpa_cli -i "$iface" remove_network "$id" >/dev/null
    wpa_cli -i "$iface" save_config >/dev/null
    info "network: forgot '$ssid'"
}

_wifi_power_wpa() {
    error "network: wifi power control not supported by wpa_supplicant"
    return 1
}


##
## Common utilities
##

_net_check_connection() {
    for url in google.com duckduckgo.com wikipedia.org; do
        ping -c 1 -W 1 "$url" >/dev/null 2>&1 && return 1
    done
    return 0
}

_wifi_list_to_json() {
    comma=false
    printf '['
    while IFS='|' read -r signal_level ssid current security saved; do
        [ -z "$ssid" ] && continue
        [ "$comma" = "true" ] && printf ','
        printf '{"ssid": "%s", "current": %s, "saved": %s, "security": "%s", "signal_level": %d}' \
            "$ssid" "$current" "$saved" "$security" "$signal_level"
        comma=true
    done
    printf ']\n'
}

_wifi_saved_to_json() {
    comma=false
    printf '['
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        [ "$comma" = "true" ] && printf ','
        printf '%s' "$line"
        comma=true
    done
    printf ']\n'
}

##
## Ethernet
##

_eth_status() {
    interfaces=$(find /sys/class/net \( -name "en*" -o -name "eth*" \) -exec basename {} \;)

    for iface in $interfaces; do
        operstate=$(cat "/sys/class/net/$iface/operstate" 2>/dev/null)
        if [ "$operstate" = "up" ]; then
            _net_check_connection && state="noconnection" || state="connected"
            printf '{"enable": 1, "state": "%s", "interface": "%s"}\n' "$state" "$iface"
            return
        fi
    done

    echo '{"enable": 0, "state": "unknown"}'
}

_eth_power() {
    cmd="$1"
    if [ "$wifi_backend" != "nmcli" ]; then
        error "network: ethernet on/off requires nmcli"
        return 1
    fi
    nmcli networking "$cmd" >/dev/null
}


##
## Interface management
##

_wifi_iface_list() {
    interfaces=$(find /sys/class/net \( -name "wlan*" -o -name "wl*" \) -exec basename {} \;)
    [ -z "$interfaces" ] && error "network: no WiFi interfaces found" && exit 1

    comma=false
    printf '['
    for iface in $interfaces; do
        [ "$comma" = "true" ] && printf ','
        printf '"%s"' "$iface"
        comma=true
    done
    printf ']\n'
}

_wifi_iface_get() {
    echo "$(_wifi_interface)"
}

_wifi_iface_set() {
    iface="$1"
    [ -z "$iface" ] && error "network: no interface name provided" && exit 1
    [ "$iface" = "$(_wifi_interface)" ] && exit 0
    [ ! -d "/sys/class/net/$iface" ] && error "network: interface '$iface' not found" && exit 1

    echo "$iface" > "$cache_wifi_interface"
    info "network: interface set to '$iface'"
}


##
## Entry point
##

_usage() {
    cat <<EOF
Usage: scripter network <command> [options]

Commands:
  wifi status                     Show current WiFi status
  wifi list [--saved]             List available networks (--saved: only saved networks)
  wifi connect <ssid> [password]  Connect to a network
  wifi disconnect                 Disconnect from current network
  wifi forget <ssid>              Forget a saved network
  wifi on | off | toggle          Enable/disable WiFi
  wifi interface list             List available WiFi interfaces
  wifi interface get              Show current WiFi interface
  wifi interface set <iface>      Set WiFi interface

  ethernet status                 Show current ethernet status
  ethernet on | off | toggle      Enable/disable ethernet (requires nmcli)

Backend: $wifi_backend
EOF
}

wifi_backend=$(_detect_wifi_backend)

case $1 in
    help | --help | -h)
        _usage
        ;;

    wifi)
        [ "$wifi_backend" = "none" ] && error "network: no WiFi backend found" && exit 1

        case $2 in
            status)
                _wifi_op status
                ;;

            list)
                case $3 in
                    --saved | "")
                        case $3 in
                            --saved) _wifi_op list_saved | _wifi_saved_to_json ;;
                            *)       _wifi_op list | _wifi_list_to_json ;;
                        esac
                        ;;
                    *)
                        error "network: unknown list option '$3'"
                        _usage
                        exit 1
                        ;;
                esac
                ;;

            connect)
                _wifi_op connect "$3" "$4"
                ;;

            forget)
                _wifi_op forget "$3"
                ;;

            on | off)
                _wifi_op power "$2"
                ;;

            toggle)
                current=$(cat "$cache_wifi_power" 2>/dev/null)
                [ "$current" = "off" ] && _wifi_op power "on" || _wifi_op power "off"
                ;;

            interface)
                case $3 in
                    list) _wifi_iface_list ;;
                    get)  _wifi_iface_get ;;
                    set)  _wifi_iface_set "$4" ;;
                    *)    error "network: unknown interface command '$3'"; _usage; exit 1 ;;
                esac
                ;;

            *)
                error "network: unknown wifi command '$2'"
                _usage
                exit 1
                ;;
        esac
        ;;

    ethernet)
        case $2 in
            status)
                _eth_status
                ;;

            on | off)
                _eth_power "$2"
                ;;

            toggle)
                _eth_power toggle
                ;;

            *)
                error "network: unknown ethernet command '$2'"
                _usage
                exit 1
                ;;
        esac
        ;;

    *)
        error "network: unknown command '$1'"
        _usage
        exit 1
        ;;
esac

