#!/usr/bin/env sh

##
## Backend detection
##

_detect_brightness_backend() {
    if command -v brightnessctl >/dev/null 2>&1; then
        echo "brightnessctl"
    elif command -v light >/dev/null 2>&1; then
        echo "light"
    elif [ -w "$(ls /sys/class/backlight/*/brightness 2>/dev/null | head -1)" ]; then
        # Raw sysfs — works if user has write permission (e.g. video group)
        echo "raw"
    else
        echo "none"
    fi
}

_list_backends() {
    printf '['
    comma='false'
    for backend in brightnessctl light raw; do
        available='false'
        case "$backend" in
            brightnessctl) command -v brightnessctl >/dev/null 2>&1 && available='true' ;;
            light)         command -v light >/dev/null 2>&1 && available='true' ;;
            raw)           [ -n "$(ls /sys/class/backlight/ 2>/dev/null)" ] && available='true' ;;
        esac

        active='false'
        [ "$backend" = "$brightness_backend" ] && active='true'

        [ "$comma" = 'true' ] && printf ','
        printf '{"backend": "%s", "available": %s, "active": %s}' \
            "$backend" "$available" "$active"
        comma='true'
    done
    printf ']\n'
}

##
## Device detection over sysfs
##

_get_sysfs_backlight() {
    device=$(ls /sys/class/backlight/ 2>/dev/null | head -1)
    [ -z "$device" ] && return 1
    echo "/sys/class/backlight/$device"
}

_get_sysfs_keyboard() {
    device=$(ls /sys/class/leds/ 2>/dev/null | grep 'kbd_backlight' | head -1)
    [ -z "$device" ] && return 1
    echo "/sys/class/leds/$device"
}

##
## Status
##

_get_status_with_changed() {
    changed="$1"
    comma='false'

    printf '{'

    screen_sysfs=$(_get_sysfs_backlight)
    if [ -n "$screen_sysfs" ]; then
        screen_cur=$(cat "$screen_sysfs/brightness" 2>/dev/null || echo "0")
        screen_max=$(cat "$screen_sysfs/max_brightness" 2>/dev/null || echo "1")
        screen_changed='false'
        [ "$changed" = "screen" ] && screen_changed='true'

        printf '"screen": {"current": "%s", "max": "%s", "changed": %s}' \
            "$screen_cur" "$screen_max" "$screen_changed"
        comma='true'
    fi

    kbd_sysfs=$(_get_sysfs_keyboard)
    if [ -n "$kbd_sysfs" ]; then
        kbd_cur=$(cat "$kbd_sysfs/brightness" 2>/dev/null || echo "0")
        kbd_max=$(cat "$kbd_sysfs/max_brightness" 2>/dev/null || echo "1")
        kbd_changed='false'
        [ "$changed" = "keyboard" ] && kbd_changed='true'

        [ "$comma" = 'true' ] && printf ','

        printf '"keyboard": {"current": "%s", "max": "%s", "changed": %s}' \
            "$kbd_cur" "$kbd_max" "$kbd_changed"
    fi

    printf '}\n'
}

_get_status() {
    _get_status_with_changed "none"
}

##
## Brightness — get
##

_brightness_get() {
    sysfs="$1"
    cur=$(cat "$sysfs/brightness" 2>/dev/null)
    max=$(cat "$sysfs/max_brightness" 2>/dev/null)
    printf '{"current": "%s", "max": "%s"}\n' "$cur" "$max"
}

##
## Brightness — watch
##

_watch() {
    # Emit initial state — nothing changed yet
    _get_status_with_changed "none"

    screen_sysfs=$(_get_sysfs_backlight)
    kbd_sysfs=$(_get_sysfs_keyboard)

    # Track last known state for change detection
    last_screen_cur=$([ -n "$screen_sysfs" ] && cat "$screen_sysfs/brightness" 2>/dev/null || echo "0")
    last_kbd_cur=$([ -n "$kbd_sysfs" ] && cat "$kbd_sysfs/brightness" 2>/dev/null || echo "0")

    _check_and_emit() {
        cur_screen_cur=$([ -n "$screen_sysfs" ] && cat "$screen_sysfs/brightness" 2>/dev/null || echo "0")
        cur_kbd_cur=$([ -n "$kbd_sysfs" ] && cat "$kbd_sysfs/brightness" 2>/dev/null || echo "0")

        changed="none"

        if [ "$cur_screen_cur" != "$last_screen_cur" ]; then
            changed="screen"
        elif [ "$cur_kbd_cur" != "$last_kbd_cur" ]; then
            changed="keyboard"
        fi

        if [ "$changed" != "none" ]; then
            _get_status_with_changed "$changed"
            last_screen_cur="$cur_screen_cur"
            last_kbd_cur="$cur_kbd_cur"
        fi
    }

    watch_files=""
    [ -n "$screen_sysfs" ] && watch_files="$watch_files $screen_sysfs/brightness"
    [ -n "$kbd_sysfs" ] && watch_files="$watch_files $kbd_sysfs/brightness"

    if [ -z "$watch_files" ]; then
        warn "brightness: no devices found, prevent loop from eating CPU"
        return 1
    fi

    if command -v inotifywait >/dev/null 2>&1; then
        # Event-driven via inotifywait
        inotifywait --quiet --monitor --event modify $watch_files 2>/dev/null |
            while IFS= read -r event; do
                _check_and_emit
            done
    else
        warn "brightness: inotifywait not found, falling back to polling"
        while true; do
            _check_and_emit
            sleep 0.1
        done
    fi
}

##
## Set backends
##

_brightness_set_brightnessctl() {
    sysfs="$1"
    value="$2"
    signal="${value%%[0-9]*}"
    num="${value#"$signal"}"

    case "$signal" in
        "+") brightnessctl_value="$signal$num" ;;
        "-") brightnessctl_value="$num$signal" ;;
        *)   brightnessctl_value="$num" ;;
    esac
    device=$(basename "$sysfs")
    brightnessctl --device "$device" set "$brightnessctl_value" >/dev/null 2>&1
}

_brightness_set_light() {
    sysfs="$1"
    value="$2"
    signal="${value%%[0-9]*}"
    num="${value#"$signal"}"
    max=$(cat "$sysfs/max_brightness" 2>/dev/null)

    case "$value" in
        *%*)
            pct="${num%%%}"
            case "$signal" in
                "+") light -A "$pct" >/dev/null 2>&1 ;;
                "-") light -U "$pct" >/dev/null 2>&1 ;;
                *)   light -S "$pct" >/dev/null 2>&1 ;;
            esac
            ;;
        *)
            pct=$(( num * 100 / max ))
            case "$signal" in
                "+") light -A "$pct" >/dev/null 2>&1 ;;
                "-") light -U "$pct" >/dev/null 2>&1 ;;
                *)   light -S "$pct" >/dev/null 2>&1 ;;
            esac
            ;;
    esac
}

_brightness_set_raw() {
    sysfs="$1"
    value="$2"

    cur=$(cat "$sysfs/brightness" 2>/dev/null)
    max=$(cat "$sysfs/max_brightness" 2>/dev/null)

    signal="${value%%[0-9]*}"
    num="${value#"$signal"}"

    case "$value" in
        *%*)
            pct="${num%%%}"
            num=$(( max * pct / 100 ))
            ;;
    esac

    case "$signal" in
        "+") result=$(( cur + num )) ;;
        "-") result=$(( cur - num )) ;;
        *)   result="$num" ;;
    esac

    [ "$result" -lt 0 ]    && result=0
    [ "$result" -gt "$max" ] && result="$max"

    if [ ! -w "$sysfs/brightness" ]; then
        error "brightness: no write permission on '$sysfs/brightness'"
        exit 1
    fi

    echo "$result" > "$sysfs/brightness"
}

_brightness_set() {
    sysfs="$1"
    value="$2"

    case "$brightness_backend" in
        brightnessctl) _brightness_set_brightnessctl "$sysfs" "$value" ;;
        light)         _brightness_set_light "$sysfs" "$value" ;;
        raw)           _brightness_set_raw "$sysfs" "$value" ;;
        none)
            error "brightness: no backend available"
            exit 1
            ;;
    esac
}

##
## Usage
##

_usage() {
    cat <<EOF
Usage: scripter brightness [--backend <backend>] <command> [options]

Commands:
  status                   Show screen and keyboard backlight status
  watch                    Emit brightness status on change

  screen get               Show current and max screen brightness
  screen set <value>       Set screen brightness (e.g. 50, 50%, +10%, -10%)

  keyboard get             Show current and max keyboard brightness
  keyboard set <value>     Set keyboard brightness

  list-backends            List available backends

Options:
  --backend <name>         Force a specific backend (brightnessctl, light, raw)

Active backend: $brightness_backend
EOF
}

##
## Entry point
##

brightness_backend=$(_detect_brightness_backend)

while [ $# -gt 0 ]; do
    case "$1" in
        --backend)
            shift
            case "$1" in
                brightnessctl | light | raw)
                    brightness_backend="$1"
                    ;;
                *)
                    error "brightness: unknown backend '$1'"
                    exit 1
                    ;;
            esac
            shift
            ;;
        *)
            break
            ;;
    esac
done

cmd="$1"
case "$cmd" in
    status)
        _get_status
        ;;

    watch)
        _watch
        ;;

    screen)
        sysfs=$(_get_sysfs_backlight)
        if [ -z "$sysfs" ]; then
            error "brightness: no backlight device found"
            exit 1
        fi

        case "$2" in
            get)   _brightness_get "$sysfs" ;;
            set)   _brightness_set "$sysfs" "$3" ;;
            *)     error "brightness: unknown command '$2'"; _usage; exit 1 ;;
        esac
        ;;

    keyboard)
        sysfs=$(_get_sysfs_keyboard)
        if [ -z "$sysfs" ]; then
            error "brightness: no keyboard backlight device found"
            exit 1
        fi

        case "$2" in
            get)   _brightness_get "$sysfs" ;;
            set)   _brightness_set "$sysfs" "$3" ;;
            *)     error "brightness: unknown command '$2'"; _usage; exit 1 ;;
        esac
        ;;

    list-backends)
        _list_backends
        ;;

    help | --help | -h)
        _usage
        ;;

    *)
        error "brightness: unknown target '$1'"
        _usage
        exit 1
        ;;
esac

# vim: ft=sh
