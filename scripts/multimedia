#!/usr/bin/env sh

##
## Helpers
##

_wpctl_volume() {
    wpctl get-volume "$1" 2>/dev/null
}

_is_muted() {
    _wpctl_volume "$1" | grep -q 'MUTED'
}

_get_volume_float() {
    _wpctl_volume "$1" | sed -ne 's/.*\([0-9]\.[0-9]\{2\}\).*/\1/p'
}

##
## Status
##

_get_status_with_changed() {
    changed="$1"  # "speaker", "mic", or "none"

    speaker_volume=$(_get_volume_float "@DEFAULT_SINK@")
    speaker_mute=0
    _is_muted "@DEFAULT_SINK@" && speaker_mute=1
    speaker_changed='false'
    [ "$changed" = "speaker" ] && speaker_changed='true'

    mic_volume=$(_get_volume_float "@DEFAULT_SOURCE@")
    mic_mute=0
    _is_muted "@DEFAULT_SOURCE@" && mic_mute=1
    mic_changed='false'
    [ "$changed" = "mic" ] && mic_changed='true'

    printf '{'
    printf '"speaker": {"volume": %s, "mute": %d, "changed": %s},' \
        "$speaker_volume" "$speaker_mute" "$speaker_changed"
    printf '"microphone": {"volume": %s, "mute": %d, "changed": %s}' \
        "$mic_volume" "$mic_mute" "$mic_changed"
    printf '}\n'
}

_get_status() {
    _get_status_with_changed "none"
}

##
## Volume — get
##

_volume_get() {
    volume=$(_get_volume_float "$1")
    mute=0
    _is_muted "$target" && mute=1
    printf '{"volume": %s, "mute": %d}\n' "$volume" "$mute"
}

##
## Volume — set
##

_volume_set() {
    target="$1"
    input="$2"

    # If muted, skip set and warn
    if _is_muted "$target"; then
        warn "multimedia: target is muted, unmute first"
        return 1
    fi

    # For wpctl all signals should be at end of value but on this
    # script all signals must be at start of the value, so conversion
    # is needed.
    #
    # E.g.:
    #   -5 -> 5-, +5 -> +5, 50 -> 50
    signal=$(echo "$input" | sed -ne 's/\([-+]*\).*/\1/p')
    value=$(echo "$input" | sed -ne 's/[^0-9]*\([0-9]*\).*/\1/p')

    # Normalize to wpctl decimal format if not using percent
    if [ -z "$percent" ]; then
        int=$(( value / 100 ))
        dec=$(( value % 100 ))
        [ ${#dec} -lt 2 ] && dec="0$dec"
        value="$int.$dec"
    fi

    case "$signal" in
        "+") wpctl_value="$value+" ;;
        "-") wpctl_value="$value-" ;;
        *)   wpctl_value="$value" ;;
    esac

    wpctl set-volume --limit 1.0 "$target" "$wpctl_value"
}

##
## Volume — mute
##

_volume_mute() {
    target="$1"
    wpctl set-mute "$target" toggle
}

##
## Volume — watch
##

_watch() {
    # Emit initial state — nothing changed yet
    _get_status_with_changed "none"

    pactl subscribe 2>/dev/null | while IFS= read -r event; do
        echo "$event" | grep -q "change" || continue

        if echo "$event" | grep -q "sink"; then
            _get_status_with_changed "speaker"
        elif echo "$event" | grep -q "source"; then
            _get_status_with_changed "mic"
        fi
    done
}

##
## Usage
##

_usage() {
    cat <<EOF
Usage: scripter multimedia <command>

Commands:
  status                          Show speaker and mic status
  watch                           Emit speaker/mic status on change

  speaker get                     Show speaker volume and mute state
  speaker set <value>             Set speaker volume (e.g. 50%, +5%, -5%)
  speaker mute                    Toggle speaker mute

  mic get                         Show mic volume and mute state
  mic set <value>                 Set mic volume
  mic mute                        Toggle mic mute
EOF
}

##
## Entry point
##

# Parse --player option
player_name=""
while [ $# -gt 0 ]; do
    case "$1" in
        --player)
            shift
            player_name="$1"
            shift
            ;;
        *)
            break
            ;;
    esac
done

cmd="$1"
case "$cmd" in
    status)
        _get_status
        ;;

    watch)
        _watch
        ;;

    speaker)
        target="@DEFAULT_SINK@"
        case "$2" in
            get)  _volume_get "$target" ;;
            set)  _volume_set "$target" "$3" ;;
            mute) _volume_mute "$target" ;;
            *)    error "multimedia: unknown speaker command '$2'"; _usage; exit 1 ;;
        esac
        ;;

    mic)
        target="@DEFAULT_SOURCE@"
        case "$2" in
            get)  _volume_get "$target" ;;
            set)  _volume_set "$target" "$3" ;;
            mute) _volume_mute "$target" ;;
            *)    error "multimedia: unknown mic command '$2'"; _usage; exit 1 ;;
        esac
        ;;

    help | --help | -h)
        _usage
        ;;

    *)
        error "multimedia: unknown command '$cmd'"
        _usage
        exit 1
        ;;
esac

# vim: ft=sh
