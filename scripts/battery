#!/usr/bin/env sh

_find_battery() {
    find /sys/class/power_supply/ -name "BAT*" | head -1
}

_cmd_status() {
    capacity=$(cat "$battery/capacity")
    status=$(cat "$battery/status" | tr '[:upper:]' '[:lower:]')
    printf '{"capacity": %s, "state": "%s"}\n' "$capacity" "$status"
}

_cmd_watch() {
    # Emit initial state
    _cmd_status "$battery"

    last_capacity=$(cat "$battery/capacity")
    last_status=$(cat "$battery/status")

    while true; do
        sleep 1.5

        cur_capacity=$(cat "$battery/capacity")
        cur_status=$(cat "$battery/status")

        if [ "$cur_capacity" != "$last_capacity" ] || [ "$cur_status" != "$last_status" ]; then
            last_capacity="$cur_capacity"
            last_status="$cur_status"
            _cmd_status "$battery"
        fi
    done
}

_cmd_help() {
    cat <<'EOF'
Usage: scripter battery <command>

Commands:
  status   Print current battery status as JSON
  watch    Emit battery status as JSON on every change
  help     Show this help message
EOF
}

battery=$(_find_battery)
if [ -z "$battery" ]; then
    error "battery: no battery found"
    exit 1
fi

[ $# -eq 0 ] && _cmd_help && exit 0
case $1 in
    status) _cmd_status ;;
    watch)  _cmd_watch ;;
    help)   _cmd_help ;;
    *)
        error "battery: unknown command '$1'"
        _cmd_help
        exit 1
        ;;
esac

# vim: ft=sh
