#!/usr/bin/env sh

##
## Cache
##

cache_dir="$SCRIPT_CACHE_DIR"
cache_mode="$cache_dir/mode"
cache_pid="$cache_dir/pid"

if [ -z "$cache_dir" ]; then
    error "color-temperature: SCRIPT_CACHE_DIR is not defined"
    exit 1
fi

mkdir -p "$cache_dir" || exit 1

if [ ! -s "$cache_mode" ]; then
    printf '%s\n' "auto" > "$cache_mode"
fi

##
## Helpers
##

_is_running() {
    pgrep -x wlsunset >/dev/null 2>&1
}

_is_wlsunset_pid() {
    pid="$1"

    case "$pid" in
        '' | *[!0-9]*) return 1 ;;
    esac

    [ "$pid" -gt 0 ] 2>/dev/null || return 1
    [ -r "/proc/$pid/comm" ] || return 1

    process_name=$(cat "/proc/$pid/comm" 2>/dev/null)
    [ "$process_name" = "wlsunset" ]
}

_get_mode() {
    mode=$(cat "$cache_mode" 2>/dev/null)

    case "$mode" in
        auto | high | low)
            printf '%s\n' "$mode"
            ;;
        *)
            printf '%s\n' "auto"
            ;;
    esac
}

_get_pid() {
    pid=$(cat "$cache_pid" 2>/dev/null)
    printf '%s\n' "$pid"
}

_set_cached_mode() {
    printf '%s\n' "$1" > "$cache_mode"
}

_normalize_mode() {
    case "$1" in
        auto | automatic)
            printf '%s\n' "auto"
            ;;

        high | day | cool)
            printf '%s\n' "high"
            ;;

        low | night | warm)
            printf '%s\n' "low"
            ;;

        *)
            return 1
            ;;
    esac
}

_get_location() {
    latitude=$("$root/_scripter" location latitude)
    longitude=$("$root/_scripter" location longitude)

    if [ -z "$latitude" ] || [ -z "$longitude" ]; then
        error "color-temperature: failed to determine location"
        return 1
    fi
}

##
## Status
##

_get_status() {
    enabled='false'
    _is_running && enabled='true'

    mode=$(_get_mode)

    printf '{"enabled": %s, "mode": "%s"}\n' \
        "$enabled" "$mode"
}

##
## Watch
##

_watch() {
    trap 'exit 0' INT TERM HUP

    _get_status

    last_enabled=$(_is_running && printf true || printf false)
    last_mode=$(_get_mode)

    while true; do
        enabled=$(_is_running && printf true || printf false)
        mode=$(_get_mode)

        if [ "$enabled" != "$last_enabled" ] || [ "$mode" != "$last_mode" ]; then
            _get_status

            last_enabled="$enabled"
            last_mode="$mode"
        fi

        sleep 0.5
    done
}

##
## Mode handling
##

_send_mode_steps() {
    pid="$1"
    steps="$2"

    step=0
    while [ "$step" -lt "$steps" ]; do
        kill -USR1 "$pid" 2>/dev/null || {
            error "color-temperature: failed to change wlsunset mode"
            return 1
        }

        step=$((step + 1))

        # Standard signals are not queued. Allow wlsunset to process the
        # current transition before sending another signal.
        if [ "$step" -lt "$steps" ]; then
            sleep 0.1
        fi
    done
}

_apply_mode() {
    pid="$1"
    current="$2"
    target="$3"

    case "$current" in
        auto | high | low) ;;
        *)
            error "color-temperature: invalid current mode '$current'"
            return 1
            ;;
    esac

    case "$target" in
        auto | high | low) ;;
        *)
            error "color-temperature: invalid target mode '$target'"
            return 1
            ;;
    esac

    # If no supervised process is available, persist the requested mode.
    # It will be restored when wlsunset starts.
    if ! _is_wlsunset_pid "$pid"; then
        rm -f "$cache_pid"
        _set_cached_mode "$target"
        return
    fi

    if [ "$target" = "$current" ]; then
        return
    fi

    case "$current:$target" in
        auto:high | high:low | low:auto)
            steps=1
            ;;

        auto:low | high:auto | low:high)
            steps=2
            ;;

        *)
            error "color-temperature: invalid mode transition '$current' → '$target'"
            return 1
            ;;
    esac

    _send_mode_steps "$pid" "$steps" || return 1
    _set_cached_mode "$target"
}

_cycle_mode() {
    current=$(_get_mode)

    case "$current" in
        auto) target="high" ;;
        high) target="low" ;;
        low) target="auto" ;;
    esac

    _apply_mode "$(_get_pid)" "$current" "$target"
}

##
## Process management
##

_start_wlsunset() {
    latitude="$1"
    longitude="$2"

    wlsunset -l "$latitude" -L "$longitude" &
    wlsunset_pid=$!

    printf '%s\n' "$wlsunset_pid" > "$cache_pid"

    # Wait until the process has initialized and installed its signal
    # handlers before sending SIGUSR1.
    sleep 0.1

    if ! kill -0 "$wlsunset_pid" 2>/dev/null; then
        wait "$wlsunset_pid" 2>/dev/null
        rm -f "$cache_pid"

        error "color-temperature: wlsunset failed to start"
        return 1
    fi

    # Restore cached mode.
    if ! _apply_mode "$wlsunset_pid" "auto" "$(_get_mode)" ||
        ! _is_wlsunset_pid "$wlsunset_pid"; then
        kill "$wlsunset_pid" 2>/dev/null
        wait "$wlsunset_pid" 2>/dev/null
        rm -f "$cache_pid"

        wlsunset_pid=''

        error "color-temperature: failed to restore cached mode"
        return 1
    fi
}

_stop_wlsunset() {
    if [ -z "${wlsunset_pid:-}" ]; then
        return
    fi

    if ! _is_wlsunset_pid "$wlsunset_pid"; then
        kill "$wlsunset_pid" 2>/dev/null
    fi

    wait "$wlsunset_pid" 2>/dev/null
    rm -f "$cache_pid"

    wlsunset_pid=''
}

_cleanup() {
    trap - INT TERM EXIT
    _stop_wlsunset
}

_run() {
    if _is_running; then
        warn "color-temperature: existing wlsunset process found, restarting under script supervision"

        if ! pkill -x wlsunset >/dev/null 2>&1; then
            error "color-temperature: failed to stop existing wlsunset process"
            return 1
        fi

        i=0
        while _is_running; do
            i=$((i + 1))

            if [ "$i" -ge 20 ]; then
                error "color-temperature: existing wlsunset process did not stop"
                return 1
            fi

            sleep 0.1
        done
    fi

    _get_location || return 1

    _start_wlsunset "$latitude" "$longitude" || return 1

    trap '_cleanup; exit 0' INT TERM
    trap '_cleanup' EXIT

    location_elapsed=0

    while true; do
        sleep 1
        location_elapsed=$((location_elapsed + 1))

        # Restart wlsunset if it exits unexpectedly and restore the cached mode.
        if ! _is_wlsunset_pid "$wlsunset_pid"; then
            wait "$wlsunset_pid" 2>/dev/null

            warn "color-temperature: wlsunset stopped, restarting"

            _get_location || {
                sleep 1
                continue
            }

            _start_wlsunset "$latitude" "$longitude" || {
                sleep 1
                continue
            }

            location_elapsed=0
            continue
        fi

        # Location does not need to be checked every second.
        if [ "$location_elapsed" -lt 30 ]; then
            continue
        fi

        location_elapsed=0

        current_latitude=$("$root/_scripter" location latitude)
        current_longitude=$("$root/_scripter" location longitude)

        if [ -z "$current_latitude" ] || [ -z "$current_longitude" ]; then
            warn "color-temperature: failed to refresh location"
            continue
        fi

        if [ "$current_latitude" != "$latitude" ] ||
            [ "$current_longitude" != "$longitude" ]; then
            latitude="$current_latitude"
            longitude="$current_longitude"

            _stop_wlsunset

            _start_wlsunset "$latitude" "$longitude" || {
                sleep 1
                continue
            }
        fi
    done
}

##
## Usage
##

_usage() {
    cat <<EOF
Usage: scripter color-temperature <command> [options]

Commands:
  status                    Show current wlsunset status and mode
  watch                     Emit status whenever state or mode changes
  run                       Start and supervise wlsunset

  set <mode>                Set the selected wlsunset mode
  cycle                     Cycle between auto, high and low

Modes:
  auto | automatic
      Automatic color temperature based on time and location

  high | day | cool
      High color temperature, cooler daytime appearance

  low | night | warm
      Low color temperature, warmer nighttime appearance

Mode cycle:
  auto → high → low → auto
EOF
}

##
## Entry point
##

if ! command -v wlsunset >/dev/null 2>&1; then
    error "color-temperature: wlsunset is not installed"
    exit 1
fi

cmd="$1"

case "$cmd" in
    status)
        if [ "$#" -ne 1 ]; then
            error "color-temperature: status takes no arguments"
            exit 1
        fi

        _get_status
        ;;

    watch)
        if [ "$#" -ne 1 ]; then
            error "color-temperature: watch takes no arguments"
            exit 1
        fi

        _watch
        ;;

    run)
        if [ "$#" -ne 1 ]; then
            error "color-temperature: run takes no arguments"
            exit 1
        fi

        _run
        ;;

    set)
        if [ "$#" -ne 2 ]; then
            error "color-temperature: expected exactly one mode"
            exit 1
        fi

        target=$(_normalize_mode "$2") || {
            error "color-temperature: unknown mode '$2'"
            exit 1
        }

        _apply_mode "$(_get_pid)" "$(_get_mode)" "$target"
        ;;

    cycle)
        if [ "$#" -ne 1 ]; then
            error "color-temperature: cycle takes no arguments"
            exit 1
        fi

        _cycle_mode
        ;;

    help | --help | -h)
        _usage
        ;;

    *)
        error "color-temperature: unknown command '$cmd'"
        _usage
        exit 1
        ;;
esac

# vim: ft=sh
