////////////////////////////////////////////////////////////////////////////////

// start some processes
spawn-at-startup "~/.config/niri/scripter" "autostart"


include "output.kdl"
include "input.kdl"
include "layout.kdl"
include "rules.kdl"
include "binds.kdl"
include "colors.kdl"
include "animations.kdl"

