# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Base setup
[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Tag-like files
[*.{xml,html}]
indent_size = 2
indent_style = space

# Makefiles
[Makefile]
indent_size = 4
indent_style = tab

